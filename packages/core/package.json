{
  "name": "@open-canvas/core",
  "version": "0.4.0",
  "description": "Runtime, Vite plugin and CLI for open-canvas — an agent-native whiteboard framework.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanyuancheung/open-canvas",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/hanyuancheung/open-canvas#readme",
  "bugs": {
    "url": "https://github.com/hanyuancheung/open-canvas/issues"
  },
  "type": "module",
  "bin": {
    "open-canvas": "./bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    }
  },
  "files": [
    "dist",
    "bin.js",
    "client.html",
    "README.md"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "rimraf dist && tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "rimraf dist && tsup"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.2",
    "kleur": "^4.1.5",
    "vite": "^5.4.11"
  },
  "optionalDependencies": {
    "pdf-lib": "^1.17.1",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
